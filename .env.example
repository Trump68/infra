# vLLM: модель с Hugging Face (для эмбеддингов или LLM)
# Примеры: BAAI/bge-small-en-v1.5, sentence-transformers/all-MiniLM-L6-v2, intfloat/e5-small-v2
VLLM_MODEL=Qwen/Qwen3-Embedding-0.6B

# Только для gated-моделей на Hugging Face
# HF_TOKEN=hf_xxxxxxxxxxxx

# PostgreSQL (опционально, есть значения по умолчанию)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=postgres

# --- Authentik (OAuth2/OIDC IdP), https://version-2026-2.goauthentik.io/install-config/install/docker-compose/ ---
# Обязательно: пароль PostgreSQL и секретный ключ (до 99 символов для PG_PASS).
# Сгенерировать: echo "PG_PASS=$(openssl rand -base64 36 | tr -d '\n')" >> .env
#               echo "AUTHENTIK_SECRET_KEY=$(openssl rand -base64 60 | tr -d '\n')" >> .env
PG_PASS=replace-with-secure-password
AUTHENTIK_SECRET_KEY=replace-with-random-secret-key
# Опционально: пользователь и БД Authentik (по умолчанию authentik/authentik)
# PG_USER=authentik
# PG_DB=authentik
# Порты (по умолчанию 9000/9443): COMPOSE_PORT_HTTP=9000 COMPOSE_PORT_HTTPS=9443
# Отчёт об ошибках: AUTHENTIK_ERROR_REPORTING__ENABLED=true

# --- Authentik (OAuth2/OIDC IdP), https://version-2026-2.goauthentik.io/install-config/install/docker-compose/ ---
# --- Kong → backend ---
# По умолчанию Kong проксирует на placeholder-сервис backend в compose. Свой API: измените url в iam/kong/kong.yml (например http://host.docker.internal:8080).
PG_PASS=60OdivX+9/iH4m0yXF/oDIvRieALHvAiDGWqCCPB7qPFVBez
AUTHENTIK_SECRET_KEY=pnGLIgKtIlx8HRzqC1Ar4JvA86p2ZNwA020EZOmTyqSdwuJkKZ7R3Esz6EMQaJoOreQesbc05LCXe5/O

# --- BFF / SPA (OIDC) — см. iam/docs/authentik.md ---
OIDC_CLIENT_ID=5Aw0CaxVsIZaCbdYBA0ZMx5uQHBifCiNdlYCyxGY
OIDC_REDIRECT_URI=http://192.168.173.157:3000/callback

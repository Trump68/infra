# vLLM: модель с Hugging Face (для эмбеддингов или LLM)
# Примеры: BAAI/bge-small-en-v1.5, sentence-transformers/all-MiniLM-L6-v2, intfloat/e5-small-v2
VLLM_MODEL=Qwen/Qwen3-Embedding-0.6B

# Только для gated-моделей на Hugging Face
# HF_TOKEN=hf_xxxxxxxxxxxx

# PostgreSQL (опционально, есть значения по умолчанию)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=postgres

# --- Authentik (OAuth2/OIDC IdP) ---
# Authentik использует тот же PostgreSQL (отдельная БД authentik). Учётные данные — POSTGRES_* выше.
# Сгенерировать: openssl rand -base64 48
AUTHENTIK_SECRET_KEY=replace-with-random-secret-key
# Опционально: автоматический токен при первом запуске (bootstrap). Токен = значение AUTHENTIK_BOOTSTRAP_TOKEN.
# Сгенерировать токен: openssl rand -base64 32
AUTHENTIK_BOOTSTRAP_TOKEN=authentik-bootstrap-token
AUTHENTIK_BOOTSTRAP_PASSWORD=admin
AUTHENTIK_BOOTSTRAP_EMAIL=admin@localhost

# --- Kong → backend ---
# По умолчанию Kong проксирует на placeholder-сервис backend в compose. Свой API: измените url в kong/kong.yml (например http://host.docker.internal:8080).
